<% content_for :head do %>
  <style>
    body.ui-lab-shell {
      margin: 0;
      min-height: 100vh;
      background: radial-gradient(circle at center, #ecf4fb 0%, #dde8f4 100%);
      padding: 0;
    }

    body.ui-lab-shell #raa-toolbar-mirror {
      --raa-font-pixel: "Geist Pixel Square", Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      position: fixed;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      display: flex;
      align-items: flex-end;
      justify-content: center;
      gap: 10px;
      width: auto;
      max-width: calc(100vw - 24px);
      color: #111827;
      font-family: Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      font-size: 12px;
      line-height: 1.4;
      z-index: 2147483645;
      pointer-events: auto;
    }

    body.ui-lab-shell #raa-toolbar-mirror .raa-main-title {
      font-family: var(--raa-font-pixel);
      font-size: 13px;
    }

    body.ui-lab-shell #raa-highlight {
      z-index: 2147483647;
    }

    body.ui-lab-shell #raa-ui-lab-update {
      position: fixed;
      top: 16px;
      right: 16px;
      z-index: 2147483647;
    }

    body.ui-lab-shell #raa-launcher {
      position: fixed;
      right: 16px;
      bottom: 16px;
    }

    body.ui-lab-shell #raa-toolbar-mirror .raa-toolbar-main,
    body.ui-lab-shell #raa-toolbar-mirror .raa-toolbar-aux {
      max-height: none;
    }

    body.ui-lab-shell #raa-toolbar-mirror .raa-toolbar-main {
      width: min(560px, calc(100vw - 24px));
    }

    body.ui-lab-shell #raa-toolbar-mirror .raa-toolbar-aux {
      width: min(460px, calc(100vw - 24px));
      order: -1;
    }

    body.ui-lab-shell #raa-toolbar-mirror .raa-panel,
    body.ui-lab-shell #raa-toolbar-mirror .raa-aux-content {
      overflow: visible;
    }

    body.ui-lab-shell #raa-toolbar-mirror input:not([type="checkbox"]),
    body.ui-lab-shell #raa-toolbar-mirror select,
    body.ui-lab-shell #raa-toolbar-mirror textarea {
      width: 100%;
      box-sizing: border-box;
    }

    @media (max-width: 980px) {
      body.ui-lab-shell #raa-toolbar-mirror {
        max-width: calc(100vw - 24px);
        flex-direction: column;
        align-items: stretch;
      }

      body.ui-lab-shell #raa-toolbar-mirror .raa-toolbar-main,
      body.ui-lab-shell #raa-toolbar-mirror .raa-toolbar-aux {
        width: auto;
      }
    }
  </style>
<% end %>

<main></main>
